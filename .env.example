# Configuration EmailJS pour DM+ Group
# Créez un compte sur https://www.emailjs.com/ et récupérez ces identifiants

VITE_EMAILJS_PUBLIC_KEY=-ymjkhCWb5uANzafN
VITE_EMAILJS_SERVICE_ID=service_bzq5gd9
VITE_EMAILJS_TEMPLATE_ID=template_qwi0hk3
VITE_EMAILJS_TEMPLATE_SUMMARY_ID=votre_template_summary_id_ici0hk3

# Instructions pour obtenir ces identifiants:
# 1. Inscrivez-vous sur https://www.emailjs.com/
# 2. Créez un service email (Gmail, Outlook, etc.)
# 3. Créez un template email avec les variables suivantes:
#    - {{to_email}} : Email de destination (yesekayumpab@gmail.com)
#    - {{from_name}} : Nom du client
#    - {{from_email}} : Email du client
#    - {{reply_to}} : Email pour réponse
#    - {{nom_entreprise}} : Nom de l'entreprise/projet
#    - {{telephone}} : Téléphone du client
#    - {{objectif_principal}} : Objectif principal
#    - {{public_cible}} : Public cible
#    - {{budget_global}} : Budget
#    - {{site_actuel}} : Site actuel
#    - Et toutes les autres variables du formulaire

# Limites gratuites EmailJS:
# - 200 emails par mois
# - 2 emails par seconde
# - Templates illimités

# Port du serveur (optionnel)
PORT=3000